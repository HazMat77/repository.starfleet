<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.starfleet"
       name="Starfleet Repository"
       version="1.0.0"
       provider-name="HazMat77">

  <requires>
    <import addon="xbmc.addon" version="12.0.0"/>
  </requires>

  <extension point="xbmc.addon.repository" name="Starfleet Repository">
    <info compressed="false">https://raw.githubusercontent.com/HazMat77/repository.starfleet/main/addons.xml</info>
    <checksum>https://raw.githubusercontent.com/HazMat77/repository.starfleet/main/addons.xml.md5</checksum>
    <datadir zip="true">https://raw.githubusercontent.com/HazMat77/repository.starfleet/main</datadir>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="en">Starfleet Repository</summary>
    <description lang="en">
      Official repository for the Starfleet Kodi addon.
      Provides plugin.video.starfleet — TV Shows, Movies, Live TV,
      Sports, Free Streaming, Adult (PIN-protected), Radio.
      Powered by TMDB, debrid services and parallel scraping.
    </description>
    <platform>all</platform>
    <license>GPL-2.0</license>
    <forum/>
    <website>https://github.com/HazMat77/repository.starfleet</website>
    <source>https://github.com/HazMat77/repository.starfleet</source>
    <news>
      v1.0.0
      - Initial release of Starfleet Repository
    </news>
  </extension>

</addon>
