<?xml version="1.0" encoding="UTF-8"?>
<addons>

<addon id="repository.starfleet"
       name="Starfleet Repository"
       version="1.0.4"
       provider-name="HazMat77">
  <requires>
    <import addon="xbmc.addon" version="12.0.0"/>
  </requires>
  <extension point="xbmc.addon.repository" name="Starfleet Repository">
    <dir>
      <info compressed="false">https://raw.githubusercontent.com/HazMat77/repository.starfleet/main/addons.xml</info>
      <checksum>https://raw.githubusercontent.com/HazMat77/repository.starfleet/main/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/HazMat77/repository.starfleet/main</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Starfleet Repository</summary>
    <description lang="en">Official repository for the Starfleet Kodi addon.</description>
    <platform>all</platform>
    <license>GPL-2.0</license>
  </extension>
</addon>

<addon id="plugin.video.starfleet"
       name="Starfleet"
       version="2.3.1"
       provider-name="HazMat77">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.22.0"/>
    <import addon="inputstream.adaptive" version="2.6.0" optional="true"/>
    <import addon="script.module.inputstreamhelper" version="0.5.9" optional="true"/>
    <import addon="repository.jsergio123" version="1.3.3" optional="true"/>
    <import addon="script.module.resolveurl" version="5.1.28" optional="true"/>
    <import addon="repository.elementumorg" version="0.0.7" optional="true"/>
    <import addon="plugin.video.elementum" version="0.1.113" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video audio</provides>
    <reuselanguageinvoker>true</reuselanguageinvoker>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Starfleet - TV, Movies, Live TV, Sports, Radio, Adult</summary>
    <description lang="en">All-in-one Kodi plugin. TV, Movies, Live TV, Sports, Free Streaming, Adult (PIN-protected), Radio. Torrent/debrid sources via Real-Debrid, AllDebrid, Premiumize, TorBox. Elementum support for magnet playback.</description>
    <platform>all</platform>
    <license>GPL-2.0</license>
    <news>v2.3.1 - Fix Tubi/Fawesome/Plex browse using TMDB discover API with watch provider filtering</news>
  </extension>
</addon>

<addon id="repository.elementumorg"
       name="ElementumOrg Repository"
       version="0.0.7"
       provider-name="elementumorg">
  <requires/>
  <extension point="xbmc.addon.repository">
    <dir>
      <info>http://127.0.0.1:65223/addons.xml</info>
      <checksum>http://127.0.0.1:65223/addons.xml.md5</checksum>
      <datadir>http://127.0.0.1:65223/</datadir>
    </dir>
  </extension>
  <extension point="xbmc.python.script" library="default.py"/>
  <extension point="xbmc.service" library="service.py"/>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="en">ElementumOrg repository</summary>
    <description lang="en">GitHub-backed repository for the Elementum torrent addon.</description>
  </extension>
</addon>

<addon id="plugin.video.elementum"
       name="Elementum"
       version="0.1.113"
       provider-name="elgatito">
  <requires>
    <import addon="xbmc.addon" version="16.0.0"/>
    <import addon="script.module.kodi-six" optional="true"/>
    <import addon="script.module.requests" version="2.9.1" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="navigation.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.service" library="service.py"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Elementum: Media streaming</summary>
    <description lang="en">Torrent finding and streaming engine for Kodi.</description>
    <platform>all</platform>
    <license>Non commercial</license>
  </extension>
</addon>

</addons>


